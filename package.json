{
  "name": "karma-public-repo",
  "private": true,
  "version": "1.0.0",
  "description": "Karma public repository dev tooling (includes optional local demo Node scripts)",
  "scripts": {
    "guard:dev": "python3 -m http.server 8787",
    "test:agent-guard": "playwright test --config=playwright.config.cjs",
    "guard:test": "playwright test --config=playwright.config.cjs",
    "guard:test:headed": "playwright test --config=playwright.config.cjs --headed",
    "simulate": "node scripts/simulate.cjs",
    "verify": "node scripts/verify.cjs",
    "proof": "node scripts/proof.cjs",
    "full": "node scripts/simulate.cjs && node scripts/verify.cjs && node scripts/proof.cjs"
  },
  "dependencies": {
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2"
  }
}
