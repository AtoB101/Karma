# Local OpenClaw + Phase 1 trade pipeline (copy to .env — do NOT use in production)
# Start API from repo root: uvicorn api.app:app --host 0.0.0.0 --port 8000

APP_ENV=development
AUTH_ENFORCE_PROTECTED_ROUTES=false
LEDGER_REQUIRE_PARTY_ACTOR=false
SETTLEMENT_MODE=offchain

# Trade launch — dev placeholders OK
TRADE_LAUNCH_REQUIRE_EIP712=false

# Relax progress/receipt signatures for OpenClaw MCP (local only)
OPENCLAW_LOCAL_PHASE1_AUTO_RELAX=true
# Or force on/off: OPENCLAW_RELAX_DELIVERY_SIGNATURES=true

DATABASE_URL=sqlite+aiosqlite:///./karma_dev.db

# OpenClaw MCP process (buyer or seller)
# KARMA_RUNTIME_URL=http://127.0.0.1:8000
# KARMA_API_KEY=karma_buyer-...
# KARMA_RUNTIME_KEY=KRM_RT_...
# KARMA_OPENCLAW_HANDOFF_PATH=./handoff.json
