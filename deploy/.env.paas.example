# PaaS example — copy to Railway / Fly secrets (do not commit real values).
# Production prelaunch: run scripts/production-prelaunch-gate.sh after filling values.

APP_ENV=production
APP_SECRET_KEY=change-me-use-strong-random-secret
AUTH_API_KEYS=buyer-001:secret-buyer,seller-001:secret-seller
AUTH_ENFORCE_PROTECTED_ROUTES=true
AUTH_ALLOW_DEV_KEY_FALLBACK=false
CORS_ALLOW_ORIGINS=https://console.example.com,https://www.example.com

DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/karma
REDIS_URL=redis://default:pass@host:6379/0
RATE_LIMIT_REDIS_FAIL_CLOSED=true

# Evidence (S3-compatible or MinIO)
MINIO_ENDPOINT=minio.example.com:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=karma-evidence
MINIO_SECURE=true

# Settlement / testnet (fill for on-chain; offchain for DB-only pilots)
SETTLEMENT_MODE=offchain
# SETTLEMENT_MODE=testnet
# TESTNET_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# TESTNET_CHAIN_ID=11155111
# KARMA_NON_CUSTODIAL_ADDRESS=0x...
# ERC20_TOKEN_ADDRESS=0x...

# Receipt / progress integrity (required in production — validated at startup)
RECEIPT_REQUIRE_SIGNATURE=true
PROGRESS_REQUIRE_SIGNATURE=true
RECEIPT_STRICT_RECENT_TIMESTAMPS=true

# Party binding when auth is enforced
LEDGER_REQUIRE_PARTY_ACTOR=true
SETTLEMENT_REQUIRE_PARTY_ACTOR=true
SETTLEMENT_REQUIRES_SUCCESS_EXECUTION_RECEIPT_FOR_SELLER_RELEASE=true

# OpenClaw outbound webhooks (optional)
OPENCLAW_WEBHOOK_URL=
OPENCLAW_WEBHOOK_SECRET=
OPENCLAW_WEBHOOK_STORE_EVENTS=false

# Console + Runtime gates (all true for production OpenClaw / trade pipeline)
RUNTIME_REQUIRE_SAVED_AUTOMATION_POLICY=true
RUNTIME_REQUIRE_TASK_AUTOMATION_READINESS=true
RUNTIME_REQUIRE_HANDOFF_ATTESTATION=true
RUNTIME_DAILY_SPEND_PERSIST=true
RUNTIME_AUTO_BIND_WALLET_ON_CREATE_KEY=true
RUNTIME_REQUIRE_WALLET_IDENTITY_BINDING=true

# Local OpenClaw only (never production): see deploy/.env.local-openclaw.example
# OPENCLAW_RELAX_DELIVERY_SIGNATURES=  # unset=auto when TRADE_LAUNCH_REQUIRE_EIP712=false

# Phase 1 — Trade launch EIP-712 (Open Wallet) — required in production
TRADE_LAUNCH_REQUIRE_EIP712=true
TRADE_LAUNCH_EIP712_CHAIN_ID=11155111
KARMA_SIGNING_BACKEND=client_only
TRADE_LAUNCH_RECORD_RUNTIME_DAILY_SPEND=true
# KARMA_SIGNING_DEV_PRIVATE_KEY=  # never in production

# OpenClaw MCP processes (buyer + seller)
# KARMA_OPENCLAW_REQUIRE_SERVER_ATTESTATION=true

# On-call (public-beta-security-gate.sh)
# SECURITY_ONCALL_PRIMARY=...
# SECURITY_ONCALL_BACKUP=...
