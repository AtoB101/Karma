# Docker testnet stack (copy to deploy/.env when using docker-compose.testnet.yml)
# NOT for production mainnet — Sepolia / invited beta only.

APP_ENV=production
APP_SECRET_KEY=replace-with-32-plus-char-random-secret
AUTH_API_KEYS=ops-admin:replace-me,buyer-demo:replace-me,seller-demo:replace-me
AUTH_ENFORCE_PROTECTED_ROUTES=true
AUTH_ALLOW_DEV_KEY_FALLBACK=false
RATE_LIMIT_REDIS_FAIL_CLOSED=true

DATABASE_URL=postgresql+asyncpg://karma:karma@postgres:5432/karma_db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/3
CELERY_RESULT_BACKEND=redis://redis:6379/4

RECEIPT_REQUIRE_SIGNATURE=true
PROGRESS_REQUIRE_SIGNATURE=true
LEDGER_REQUIRE_PARTY_ACTOR=true
SETTLEMENT_REQUIRE_PARTY_ACTOR=true
RUNTIME_REQUIRE_SAVED_AUTOMATION_POLICY=true
RUNTIME_REQUIRE_TASK_AUTOMATION_READINESS=true
RUNTIME_REQUIRE_HANDOFF_ATTESTATION=true
RUNTIME_REQUIRE_WALLET_IDENTITY_BINDING=true
RUNTIME_DAILY_SPEND_PERSIST=true
TRADE_LAUNCH_REQUIRE_EIP712=false
OPENCLAW_LOCAL_PHASE1_AUTO_RELAX=false
OPENCLAW_RELAX_DELIVERY_SIGNATURES=false
KARMA_SIGNING_BACKEND=client_only
X402_PAYMENT_BACKEND=sepolia
X402_ENABLED=true

SETTLEMENT_MODE=testnet
TESTNET_CHAIN_ID=11155111
# TESTNET_RPC_URL=
# KARMA_NON_CUSTODIAL_ADDRESS=
# ERC20_TOKEN_ADDRESS=

ADMIN_ACTOR_IDS=ops-admin
SECURITY_ONCALL_PRIMARY=oncall-primary@example.com
SECURITY_ONCALL_BACKUP=oncall-backup@example.com

OPENCLAW_WEBHOOK_MAX_RETRIES=3
PAYMENT_INTENT_EXPIRE_ENABLED=true
