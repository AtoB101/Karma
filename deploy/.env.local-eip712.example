# Local Phase 1 path B — Trade launch EIP-712 with server-side sign (dev/CI only)
# Requires buyer identity bound_wallet_address matching KARMA_SIGNING_DEV_PRIVATE_KEY
# Copy to .env and start API from repo root.

APP_ENV=development
AUTH_ENFORCE_PROTECTED_ROUTES=false
LEDGER_REQUIRE_PARTY_ACTOR=false
SETTLEMENT_MODE=offchain

TRADE_LAUNCH_REQUIRE_EIP712=true
KARMA_SIGNING_BACKEND=env
KARMA_SIGNING_DEV_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Do NOT enable delivery relax when testing EIP-712 launch path
OPENCLAW_LOCAL_PHASE1_AUTO_RELAX=false
OPENCLAW_RELAX_DELIVERY_SIGNATURES=false

DATABASE_URL=sqlite+aiosqlite:///./karma_dev.db
