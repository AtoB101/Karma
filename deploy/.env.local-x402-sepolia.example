# Phase 2 path C — x402 with real Sepolia USDC transfer
# Copy to .env; fund payer with Sepolia USDC + ETH for gas.

APP_ENV=development
X402_ENABLED=true
X402_PAYMENT_BACKEND=sepolia
X402_ALLOW_PRIVATE_HOSTS=true
X402_DEFAULT_MAX_BUDGET_USDC=1
X402_HARD_MAX_BUDGET_USDC=10

TESTNET_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
TESTNET_CHAIN_ID=11155111
ERC20_TOKEN_ADDRESS=0xYourSepoliaUSDC
KARMA_SIGNING_DEV_PRIVATE_KEY=0xYourPayerPrivateKey

TRADE_LAUNCH_REQUIRE_EIP712=false
OPENCLAW_LOCAL_PHASE1_AUTO_RELAX=true
