# Buyer OpenClaw process — copy to buyer.env (gitignored locally)
KARMA_RUNTIME_URL=http://localhost:8000
KARMA_API_KEY=karma_buyer-REPLACE_secret
# Optional Runtime Key (mint in Console, not via MCP):
# KARMA_RUNTIME_KEY=KRM_RT_...
KARMA_OPENCLAW_HANDOFF_PATH=./handoff.json
# Buyer settlement accept / progress confirm — default Console-only:
# KARMA_OPENCLAW_ALLOW_BUYER_ACCEPT=true
# KARMA_OPENCLAW_ALLOW_BUYER_CONFIRM=true
