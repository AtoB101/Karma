# Seller OpenClaw process — copy to seller.env (gitignored locally)
KARMA_RUNTIME_URL=http://localhost:8000
KARMA_API_KEY=karma_seller-REPLACE_secret
# Recommended for submit-receipt / request-settlement without API-only path:
# KARMA_RUNTIME_KEY=KRM_RT_...
KARMA_OPENCLAW_HANDOFF_PATH=./handoff.json
# Optional: Karma API pushes voucher.accepted / settlement.* (see docs/openclaw-handoff-webhook-v1.md)
# OPENCLAW_WEBHOOK_URL=http://127.0.0.1:8765/hook
# OPENCLAW_WEBHOOK_SECRET=devsecret
