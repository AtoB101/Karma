{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://karma.example/schemas/evidence-bundle-public-1.0.json",
  "title": "KARMA public evidence bundle (v1.0)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_version",
    "bill_id",
    "agent_id",
    "buyer_wallet",
    "seller_wallet",
    "service_type",
    "price",
    "token",
    "input_hash",
    "output_hash",
    "execution_result",
    "failure_reason",
    "started_at",
    "completed_at",
    "model_or_runtime",
    "evidence_uri",
    "signature",
    "settlement_status",
    "dispute_status"
  ],
  "properties": {
    "evidence_version": { "type": "string", "const": "1.0" },
    "bill_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "buyer_wallet": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" },
    "seller_wallet": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" },
    "service_type": { "type": "string" },
    "price": { "type": "string" },
    "token": { "type": "string" },
    "input_hash": { "type": "string" },
    "output_hash": { "type": "string" },
    "execution_result": { "type": "string" },
    "failure_reason": { "type": "string" },
    "started_at": { "type": "string" },
    "completed_at": { "type": "string" },
    "model_or_runtime": { "type": "string" },
    "evidence_uri": { "type": "string" },
    "signature": { "type": "string" },
    "settlement_status": { "type": "string" },
    "dispute_status": { "type": "string" }
  }
}
