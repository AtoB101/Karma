{
  "name": "@karma/sdk",
  "version": "1.0.0",
  "description": "Minimal TypeScript client for KarmaBilateral — lock / bind / settle in three lines",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test":  "vitest run"
  },
  "peerDependencies": {
    "ethers": ">=6.0"
  },
  "peerDependenciesMeta": {
    "ethers": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^3.0.5",
    "ethers": "^6.13.0"
  },
  "license": "MIT",
  "keywords": ["karma", "agents", "billing", "usdc", "bill-token", "defi"]
}
