# ============================================================
# Karma Trust Protocol — Environment Configuration
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-32-char-string
DEBUG=false

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://karma:karma@localhost:5432/karma_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_EVIDENCE=karma-evidence
MINIO_BUCKET_RECEIPTS=karma-receipts
MINIO_SECURE=false

# LLM (optional — only needed for LangChain tools)
OPENAI_API_KEY=sk-placeholder

# Ed25519 signing keys (auto-generated on first run if missing)
ED25519_PRIVATE_KEY_PATH=./keys/agent_private.pem
ED25519_PUBLIC_KEY_PATH=./keys/agent_public.pem

# Private runtime (internal — not public internet)
PRIVATE_RUNTIME_URL=http://localhost:8001
PRIVATE_RUNTIME_API_KEY=change-me-runtime-key

# Settlement
ESCROW_MIN_AMOUNT=0.01
ESCROW_MAX_AMOUNT=10000.0
DISPUTE_WINDOW_HOURS=72
ARBITRATION_TIMEOUT_HOURS=168

# Celery
CELERY_BROKER_URL=redis://localhost:6379/3
CELERY_RESULT_BACKEND=redis://localhost:6379/4

# Monitoring
LOG_LEVEL=INFO
