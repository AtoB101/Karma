# ============================================================
# Karma Private Runtime — Environment Configuration
# CONFIDENTIAL. Never commit. Never expose publicly.
# ============================================================

# Runtime
RUNTIME_HOST=127.0.0.1
RUNTIME_PORT=8001
RUNTIME_API_KEY=change-me-runtime-key

# Database (same cluster as public API)
DATABASE_URL=postgresql+asyncpg://karma:karma@localhost:5432/karma_db
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Ed25519 keys (can share with public or use separate runtime keys)
ED25519_PRIVATE_KEY_PATH=./keys/runtime_private.pem
ED25519_PUBLIC_KEY_PATH=./keys/runtime_public.pem

# Monitoring
LOG_LEVEL=INFO
