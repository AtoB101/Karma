# Phase 3 — testnet / hybrid (do NOT commit real secrets; copy to local .env only)

TESTNET_RPC_URL=
# Optional; chain id is read from the RPC when omitted.
TESTNET_CHAIN_ID=

# Wallets (never commit populated keys)
TESTNET_BUYER_PRIVATE_KEY=
TESTNET_SELLER_PRIVATE_KEY=
# Seller EOA address (must differ from buyer); used as createBill `seller`.
TESTNET_SELLER_ADDRESS=

NONCUSTODIAL_AGENT_PAYMENT_ADDRESS=
ERC20_TOKEN_ADDRESS=

# Bill sizing (token smallest units)
BILL_AMOUNT_WEI=1000000
# Optional lock overrides for lockFunds capacity (defaults scale from amount + sellerBondBps)
BUYER_LOCK_WEI=
SELLER_LOCK_WEI=
BILL_DEADLINE_UNIX=

# Stepwise createBill (also embedded in hybrid_settlement_result.json from full_flow)
KARMA_PROOF_HASH=
KARMA_SCOPE_HEX=

# offchain | hybrid | testnet (informational; --send always performs on-chain steps)
SETTLEMENT_MODE=hybrid
