FROM python:3.12-slim
WORKDIR /workspace
COPY requirements-bff.txt /workspace/requirements-bff.txt
RUN pip install --no-cache-dir -r /workspace/requirements-bff.txt
COPY apps /workspace/apps
COPY trusted_agent_runtime /workspace/trusted_agent_runtime
ENV PYTHONPATH=/workspace
EXPOSE 8820
CMD ["uvicorn", "apps.karma_bff.app.main:app", "--host", "0.0.0.0", "--port", "8820"]
