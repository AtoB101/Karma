# Example environment for local docker-compose overlays.
# Copy to a gitignored file (e.g. .env.local) — never commit real keys.

# Optional: bind host for published static image
# STATIC_PORT=8080

# Public API base URL your Console will call (must be server-side signed in production)
# KARMA_PUBLIC_API_BASE=https://api.example.com

# Testnet RPC (for local tooling only)
# TESTNET_RPC_URL=
